{
  "annotations": { "list": [] },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Total Services",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "datasource": "Prometheus",
      "targets": [
        { "expr": "count(service_up)", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Services Up",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "datasource": "Prometheus",
      "targets": [
        { "expr": "sum(service_up)", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": null, "color": "red" }, { "value": 1, "color": "green" }]
          },
          "unit": "none"
        },
        "overrides": []
      }
    },
    {
      "type": "table",
      "title": "Microservices Status",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 4 },
      "id": 3,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "max(max_over_time(service_up[5m])) by (job)",
          "format": "table",
          "legendFormat": "{{job}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red",   "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "N/A", "color": "gray", "index": 2 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "red" },
              { "value": 1,    "color": "green" }
            ]
          },
          "unit": "none"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {},
            "renameByName": {
              "job":   "Job",
              "Value": "Status",
              "Time":  "Last Updated"
            },
            "indexByName": {
              "job":   0,
              "Value": 1,
              "Time":  2
            }
          }
        }
      ]
    },
    {
      "type": "graph",
      "title": "Process Resident Memory (Bytes) by Job",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 4,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_resident_memory_bytes",
          "refId": "B",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "fill": 1
    },
    {
      "type": "graph",
      "title": "CPU Seconds Total by Job",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 5,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_cpu_seconds_total",
          "refId": "C",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "fill": 1
    },
    {
      "type": "graph",
      "title": "Open File Descriptors by Job",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "id": 6,
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "process_open_fds",
          "refId": "D",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list" } },
      "lines": true,
      "points": false,
      "linewidth": 2,
      "fill": 1
    }
  ],
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["microservices", "status", "python", "metrics"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Microservices Up & System Metrics",
  "version": 1
}